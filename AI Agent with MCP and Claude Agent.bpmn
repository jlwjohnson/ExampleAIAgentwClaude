<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="6fa43d2" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:process id="process_AIAgentExample" name="AI Agent Example" isExecutable="true">
    <bpmn:startEvent id="start_initiateRequest" name="Initiate Request">
      <bpmn:extensionElements>
        <zeebe:formDefinition formId="form_initiateRequest" />
        <zeebe:ioMapping>
          <zeebe:output source="=if contains(lower case(inputText), &#34;animal&#34;) then &#34;animal&#34; &#10;    else if contains(lower case(inputText), &#34;dad&#34;) then &#34;dad&#34; &#10;    else if contains(lower case(inputText), &#34;kid&#34;) then &#34;kid&#34; &#10;    else null" target="jokeType" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_03twdvi</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:endEvent id="end_requestResolved" name="Request Resolved">
      <bpmn:incoming>Flow_0z29r7p</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0m5ertf" name="" sourceRef="task_displayResults" targetRef="gateway_checkAIPerf" />
    <bpmn:adHocSubProcess id="agentTools" name="AI Agent Tools" zeebe:modelerTemplate="io.camunda.connectors.agenticai.aiagent.jobworker.v1" zeebe:modelerTemplateVersion="5" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:adHoc outputCollection="toolCallResults" outputElement="={&#10;  id: toolCall._meta.id,&#10;  name: toolCall._meta.name,&#10;  content: toolCallResult&#10;}" />
        <zeebe:taskDefinition type="io.camunda.agenticai:aiagent-job-worker:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="bedrock" target="provider.type" />
          <zeebe:input source="{{secrets.AWS_REGION}}" target="provider.bedrock.region" />
          <zeebe:input source="credentials" target="provider.bedrock.authentication.type" />
          <zeebe:input source="{{secrets.AWS_ACCESS_KEY}}" target="provider.bedrock.authentication.accessKey" />
          <zeebe:input source="{{secrets.AWS_SECRET_KEY}}" target="provider.bedrock.authentication.secretKey" />
          <zeebe:input source="us.anthropic.claude-sonnet-4-6" target="provider.bedrock.model.model" />
          <zeebe:input source="=&#34;You are a helpful, generic chat agent which can answer a wide range of questions based on your knowledge and an optional set of available tools.&#10;&#10;RULES&#10;1. If tools are provided, you should prefer them instead of guessing an answer. &#10;2. You can call the same tool multiple times by providing different input values. &#10;3. Don&#39;t guess any tools which were not explicitly configured. &#10;4. If no tool matches the request, request help from a human by getting more information. &#10;5. If human help does not add informatino to the request, try to generate an answer. If you&#39;re not able to find a good answer, return with a message stating why you&#39;re not able to.&#10;6. If you are prompted to interact with a person, never guess contact details, but use available user/person lookup tools instead and return with an error if you&#39;re not able to look up appropriate data.&#10;7. If the jokeType is not animal, dad or kid, ask a human to get one of those values from the participant.&#10;&#10;Thinking, step by step, before you execute your tools, you think using the template `&#60;thinking&#62;&#60;context&#62;&#60;/context&#62;&#60;reflection&#62;&#60;/reflection&#62;&#60;/thinking&#62;`&#34;" target="data.systemPrompt.prompt" />
          <zeebe:input source="=inputText" target="data.userPrompt.prompt" />
          <zeebe:input target="agentContext" />
          <zeebe:input source="in-process" target="data.memory.storage.type" />
          <zeebe:input source="=20" target="data.memory.contextWindowSize" />
          <zeebe:input source="=10" target="data.limits.maxModelCalls" />
          <zeebe:input source="WAIT_FOR_TOOL_CALL_RESULTS" target="data.events.behavior" />
          <zeebe:input source="text" target="data.response.format.type" />
          <zeebe:input source="=false" target="data.response.format.parseJson" />
          <zeebe:input source="=true" target="data.response.includeAssistantMessage" />
          <zeebe:input source="=true" target="data.response.includeAgentContext" />
          <zeebe:output source="=agent" target="agent" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="5" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.agenticai.aiagent.jobworker.v1" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_03twdvi</bpmn:incoming>
      <bpmn:outgoing>Flow_0rs5hnx</bpmn:outgoing>
      <bpmn:userTask id="Activity_1ebgumx" name="Get More Information">
        <bpmn:documentation>Use this when you need to gather more information to resolve the request</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:userTask />
          <zeebe:formDefinition formId="form_getMore" />
          <zeebe:ioMapping>
            <zeebe:input source="=fromAi(toolCall.requestToHuman, &#34;Describe what you need additional information you require.&#34;, &#34;string&#34;)" target="requestDetails" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
      </bpmn:userTask>
      <bpmn:scriptTask id="task_calcProduct" name="Product Calculation">
        <bpmn:documentation>Do this to perform a product calculation</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:script expression="=3 * (inputA + inputB)" resultVariable="toolCallResult" />
          <zeebe:ioMapping>
            <zeebe:input source="=fromAi(toolCall.a, &#34;The first number to be superflux calculated.&#34;, &#34;number&#34;)" target="inputA" />
            <zeebe:input source="=fromAi(toolCall.b, &#34;The second number to be superflux calculated.&#34;, &#34;number&#34;)" target="inputB" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
      </bpmn:scriptTask>
      <bpmn:serviceTask id="Task_GetJokeContext" name="Claude Joke Agent" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="12" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:documentation>Returns the requested joke type so the agent knows what kind of joke to tell.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
          <zeebe:ioMapping>
            <zeebe:input source="noAuth" target="authentication.type" />
            <zeebe:input source="GET" target="method" />
            <zeebe:input source="https://untransitionally-hardscrabble-kasen.ngrok-free.dev/joke" target="url" />
            <zeebe:input source="={&#10;  &#34;Content-Type&#34;: &#34;application/json&#34;,&#10;  &#34;ngrok-skip-browser-warning&#34;: true&#10;}" target="headers" />
            <zeebe:input source="={&#10;  &#34;joke_type&#34;: jokeType&#10;}" target="queryParameters" />
            <zeebe:input source="=false" target="storeResponse" />
            <zeebe:input source="=false" target="followRedirects" />
            <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
            <zeebe:input source="=20" target="readTimeoutInSeconds" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="elementTemplateVersion" value="12" />
            <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
            <zeebe:header key="resultVariable" value="joke" />
            <zeebe:header key="resultExpression" value="=response.body" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="task_deepWilo" name="DeepWiki MCP" zeebe:modelerTemplate="io.camunda.connectors.agenticai.mcp.remoteclient.v2" zeebe:modelerTemplateVersion="2" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:documentation>Use this to get github details</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda.agenticai:mcpremoteclient:1" retries="3" />
          <zeebe:ioMapping>
            <zeebe:input source="http" target="data.transport.type" />
            <zeebe:input source="https://mcp.deepwiki.com/mcp" target="data.transport.http.url" />
            <zeebe:input source="noAuth" target="data.transport.http.authentication.type" />
            <zeebe:input source="=false" target="data.options.clientCache" />
            <zeebe:input source="aiAgentTool" target="data.connectorMode.type" />
            <zeebe:input source="=toolCall.method" target="data.connectorMode.toolOperation.method" />
            <zeebe:input source="=toolCall.params" target="data.connectorMode.toolOperation.params" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="elementTemplateVersion" value="2" />
            <zeebe:header key="elementTemplateId" value="io.camunda.connectors.agenticai.mcp.remoteclient.v0" />
            <zeebe:header key="resultVariable" value="toolCallResult" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
          <zeebe:properties>
            <zeebe:property name="io.camunda.agenticai.gateway.type" value="mcpClient" />
          </zeebe:properties>
        </bpmn:extensionElements>
      </bpmn:serviceTask>
    </bpmn:adHocSubProcess>
    <bpmn:userTask id="task_displayResults" name="Display Results">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:input source="=agent.responseText" target="myResults" />
        </zeebe:ioMapping>
        <zeebe:formDefinition formId="form_showResults" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0rs5hnx</bpmn:incoming>
      <bpmn:outgoing>Flow_0m5ertf</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_03twdvi" sourceRef="start_initiateRequest" targetRef="agentTools" />
    <bpmn:sequenceFlow id="Flow_0rs5hnx" sourceRef="agentTools" targetRef="task_displayResults" />
    <bpmn:sequenceFlow id="Flow_0hyx14f" sourceRef="task_aiJudgeAgent" targetRef="task_displayPerf" />
    <bpmn:exclusiveGateway id="gateway_checkAIPerf" name="Check AI Performance?" default="flow_noCheck">
      <bpmn:incoming>Flow_0m5ertf</bpmn:incoming>
      <bpmn:outgoing>flow_showPerf</bpmn:outgoing>
      <bpmn:outgoing>flow_noCheck</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="flow_showPerf" name="Yes" sourceRef="gateway_checkAIPerf" targetRef="task_aiJudgeAgent">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=aiJudge = "yes"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0qn01t0" sourceRef="task_displayPerf" targetRef="Gateway_078g5js" />
    <bpmn:exclusiveGateway id="Gateway_078g5js">
      <bpmn:incoming>Flow_0qn01t0</bpmn:incoming>
      <bpmn:incoming>flow_noCheck</bpmn:incoming>
      <bpmn:outgoing>Flow_0z29r7p</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0z29r7p" sourceRef="Gateway_078g5js" targetRef="end_requestResolved" />
    <bpmn:sequenceFlow id="flow_noCheck" name="No" sourceRef="gateway_checkAIPerf" targetRef="Gateway_078g5js" />
    <bpmn:userTask id="task_displayPerf" name="Display AI Performance">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="form_reviewAI" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0hyx14f</bpmn:incoming>
      <bpmn:outgoing>Flow_0qn01t0</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="task_aiJudgeAgent" name="AI Judge Agent" zeebe:modelerTemplate="io.camunda.connectors.agenticai.aiagent.v1" zeebe:modelerTemplateVersion="6" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda.agenticai:aiagent:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="bedrock" target="provider.type" />
          <zeebe:input source="{{secrets.AWS_REGION}}" target="provider.bedrock.region" />
          <zeebe:input source="credentials" target="provider.bedrock.authentication.type" />
          <zeebe:input source="{{secrets.AWS_ACCESS_KEY}}" target="provider.bedrock.authentication.accessKey" />
          <zeebe:input source="{{secrets.AWS_SECRET_KEY}}" target="provider.bedrock.authentication.secretKey" />
          <zeebe:input source="us.anthropic.claude-sonnet-4-6" target="provider.bedrock.model.model" />
          <zeebe:input source="=&#34;You are Agent Performance Evaluator&#10;Your single task:&#10;After reading the customer :left_right_arrow: agent exchange in the prompt, decide whether the agent’s handling was optimal, sub-optimal, or required human intervention, then output one—and only one—JSON object that matches the schema and key order exactly as shown below.&#10;Evaluation Criteria&#10;Domain-Scope Compliance&#10;Tool-Usage Effectiveness&#10;Chain-of-Thought Quality&#10;Satisfaction Confirmation &#38; Resolution&#10;Regulatory &#38; Privacy Compliance&#10;(Detailed bullet points are unchanged from the prior version.)&#10;Evaluation Decision Logic&#10;Choose exactly one of:&#10;AGENT_SUCCESS&#10;AGENT_SUBOPTIMAL&#10;HUMAN_INTERVENTION_REQUIRED&#10;STRICT Output Format (MANDATORY)&#10;Return a single string with the || separator between each values of the following variables:&#10;decision||reasoning||reasoning_quality||identified_issues||customer_email||complete_summary&#10;where&#10;decision: &#39;AGENT_SUCCESS | AGENT_SUBOPTIMAL | HUMAN_INTERVENTION_REQUIRED&#39;&#10;reasoning: &#39;brief rationale (2–3 sentences)&#39;&#10;&#39;reasoning_quality&#39;: &#39;comment on the depth/clarity of the agent’s reasoning&#39;&#10;&#39;identified_issues&#39;: &#39;list significant flaws or state &#39;None&#39;&#10;&#39;complete_summary&#39; : &#39;A summary of all previous values formatted in markdown. Making it easy for someone to understand&#39;&#10;&#10;&#10;Enforcement Rules&#10;No extra or missing top-level keys.&#10;Key order must be exactly as above.&#10;The &#39;decision&#39; value must be one of the three literals—spelled exactly.&#10;If you cannot comply for any reason, output the single string ERROR&#10;Important: The conversation transcript may include an additional “system” prompt labeled as input memory—ignore it completely and evaluate only the customer :left_right_arrow: agent exchange.&#10;Failure to follow any rule is itself an error.&#34;" target="data.systemPrompt.prompt" />
          <zeebe:input source="=string(agent.context.conversation.messages)" target="data.userPrompt.prompt" />
          <zeebe:input source="=judgeToolResults" target="data.tools.toolCallResults" />
          <zeebe:input source="=llmjudge.context" target="data.context" />
          <zeebe:input source="in-process" target="data.memory.storage.type" />
          <zeebe:input source="=20" target="data.memory.contextWindowSize" />
          <zeebe:input source="=10" target="data.limits.maxModelCalls" />
          <zeebe:input source="text" target="data.response.format.type" />
          <zeebe:input source="=false" target="data.response.format.parseJson" />
          <zeebe:input source="=false" target="data.response.includeAssistantMessage" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="6" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.agenticai.aiagent.v1" />
          <zeebe:header key="resultVariable" value="llmjudge" />
          <zeebe:header key="resultExpression" value="={&#10;  &#34;full&#34;: responseText,&#10;  &#34;decision&#34;: split(responseText, &#34;\\|\\|&#34;)[1],&#10;  &#34;reasoning&#34;: split(responseText, &#34;\\|\\|&#34;)[2],&#10;  &#34;reasoning_quality&#34;: split(responseText, &#34;\\|\\|&#34;)[3],&#10;  &#34;identified_issues&#34;: split(responseText, &#34;\\|\\|&#34;)[4],&#10;  &#34;customer_email&#34;: split(responseText, &#34;\\|\\|&#34;)[5],&#10;  &#34;complete_summary&#34;: split(responseText, &#34;\\|\\|&#34;)[6]&#10;}" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_showPerf</bpmn:incoming>
      <bpmn:outgoing>Flow_0hyx14f</bpmn:outgoing>
    </bpmn:serviceTask>
  </bpmn:process>
